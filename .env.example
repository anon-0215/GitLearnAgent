# Optional GitHub token. Public repositories can work without it, but the token raises API limits.
GITHUB_TOKEN=

# OpenAI-compatible LLM endpoint. DeepSeek-style defaults are used when these are unset.
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# V2 dense embedding retrieval. Keep disabled unless sentence-transformers
# and a compatible torch build are installed in the backend environment.
EMBEDDING_ENABLED=false
EMBEDDING_MODEL_NAME_OR_PATH=BAAI/bge-m3
EMBEDDING_DEVICE=auto
EMBEDDING_BATCH_SIZE=8
EMBEDDING_MAX_LENGTH=8192
EMBEDDING_NORMALIZE=true
EMBEDDING_CACHE_DIR=embedding_cache
EMBEDDING_QUERY_PREFIX=
EMBEDDING_DOCUMENT_PREFIX=

# Frontend can override the backend address with this variable.
VITE_API_BASE_URL=http://127.0.0.1:8000

