# Optional GitHub token. Public repositories can work without it, but the token raises API limits.
GITHUB_TOKEN=

# OpenAI-compatible LLM endpoint. DeepSeek-style defaults are used when these are unset.
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# Frontend can override the backend address with this variable.
VITE_API_BASE_URL=http://127.0.0.1:8000

